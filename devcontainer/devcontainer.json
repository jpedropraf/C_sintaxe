{
  "name": "desenvolvimento c",
  "image": "://mcr.microsoft.com",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2.5.7.5.7": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "jeff-hykin.better-cpp-syntax",
        "ms-vscode.cmake-tools"
      ]
    }
  },
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y build-essential gdb valgrind",
  "remoteUser": "vscode"
}